# Copy this file to .env.local for local development.
# Get these from your Alpaca dashboard (app.alpaca.markets) — a free
# paper-trading account works fine, no funding required.
ALPACA_API_KEY_ID=your_key_id_here
ALPACA_API_SECRET_KEY=your_secret_key_here

# Protects /admin and /api/admin/* with HTTP Basic Auth. Pick your own
# values — these are NOT shipped with any default, the middleware blocks
# access entirely if either is missing.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=pick_something_only_you_know
